{
  "name": "cctrackr",
  "version": "0.1.2",
  "description": "Claude Code usage analytics — accurate metrics and a beautiful HTML dashboard from local JSONL files",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "cctrackr": "dist/index.js"
  },
  "files": [
    "dist",
    "pricing"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "anthropic",
    "claude-code",
    "usage",
    "analytics",
    "dashboard",
    "cost",
    "token",
    "cli",
    "ai",
    "llm",
    "billing",
    "pricing",
    "developer-tools"
  ],
  "author": "azharuddinkhan3005",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azharuddinkhan3005/cctrack.git"
  },
  "homepage": "https://github.com/azharuddinkhan3005/cctrack#readme",
  "bugs": {
    "url": "https://github.com/azharuddinkhan3005/cctrack/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
